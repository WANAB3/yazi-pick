#!/usr/bin/env bash
# yazi-pick [start-dir]: pick a file with yazi and type its path into the
# frontmost app's file open dialog (NSOpenPanel).
# Usage: invoke from a hotkey while a file dialog is in front.
# An optional argument sets yazi's starting directory (defaults to $HOME).
#
# Fast path (both optional, both degrade gracefully):
#   - kitty: a hidden resident instance serves picker windows over a socket,
#     so the panel appears in ~0.1s instead of a ~0.7s cold start.
#   - yazi-pick-ax: a small native helper that drives the dialog through the
#     Accessibility API in-process (osascript needs ~50-150ms of Apple Events
#     IPC per query). Build it from helper/ and put it next to this script.
set -u

# Hotkey daemons (AeroSpace etc.) often launch us without a locale; without
# an explicit UTF-8 locale yazi garbles multibyte paths.
export LANG=${LANG:-en_US.UTF-8}
export LC_ALL=${LC_ALL:-$LANG}

# Hotkey daemons rarely have package-manager bins on PATH, so also probe
# the usual install locations (Homebrew / nix).
YAZI=''
for y in "$(command -v yazi 2>/dev/null)" /opt/homebrew/bin/yazi /usr/local/bin/yazi "/etc/profiles/per-user/$USER/bin/yazi"; do
    if [ -n "$y" ] && [ -x "$y" ]; then
        YAZI=$y
        break
    fi
done
if [ -z "$YAZI" ]; then
    printf 'yazi-pick: yazi not found\n' >&2
    exit 1
fi
LOG=${TMPDIR:-/tmp}/yazi-pick.log

# Native AX helper (optional): same directory as this script, then PATH.
HELPER=''
for h in "$(dirname "$0")/yazi-pick-ax" "$(command -v yazi-pick-ax 2>/dev/null)"; do
    if [ -n "$h" ] && [ -x "$h" ]; then
        HELPER=$h
        break
    fi
done

# ── Terminal detection ─────────────────────────────────────
# Requirement: run a command in a new window (new process) and block until
# it exits. Set YAZI_PICK_TERM=kitty|ghostty|wezterm|alacritty to force one
# (otherwise autodetected in that order).
term_bin() { # $1=command name $2=.app bundle name → executable path
    command -v "$1" 2>/dev/null && return 0
    local p
    for p in "/Applications/$2.app/Contents/MacOS/$1" "$HOME/Applications/$2.app/Contents/MacOS/$1"; do
        if [ -x "$p" ]; then
            printf '%s\n' "$p"
            return 0
        fi
    done
    return 1
}

term_name='' term=''
for t in ${YAZI_PICK_TERM:-kitty ghostty wezterm alacritty}; do
    case $t in
        kitty) term=$(term_bin kitty kitty) || continue ;;
        ghostty) term=$(term_bin ghostty Ghostty) || continue ;;
        wezterm) term=$(term_bin wezterm WezTerm) || continue ;;
        alacritty) term=$(term_bin alacritty Alacritty) || continue ;;
        *)
            printf 'yazi-pick: unsupported terminal: %s\n' "$t" >&2
            exit 1
            ;;
    esac
    term_name=$t
    break
done
if [ -z "$term_name" ]; then
    printf 'yazi-pick: no supported terminal found (kitty/ghostty/wezterm/alacritty)\n' >&2
    exit 1
fi

# Run the given command in a new window and block until it closes.
run_picker() {
    case $term_name in
        kitty)
            # One-shot instance. Same panel styling used elsewhere; the helper
            # centers it Spotlight-style once the window appears.
            "$term" --title yazi-picker \
                -o remember_window_size=no \
                -o initial_window_width=110c -o initial_window_height=30c \
                -o hide_window_decorations=titlebar-only \
                -o window_padding_width=10 \
                -o background_opacity=0.94 -o background_blur=40 \
                "$@" &
            local _tpid=$!
            [ -n "$HELPER" ] && ( "$HELPER" center "$_tpid" 2>>"$LOG" || true ) &
            wait "$_tpid"
            ;;
        ghostty)
            # Requires Ghostty >= 1.2.0 (earlier versions cannot be launched from
            # the CLI). Config arguments must precede -e.
            # abnormal-command-exit-runtime: keeps the window from lingering (and
            # blocking us forever) when yazi exits immediately -- on macOS an exit
            # within 250ms counts as abnormal even with exit code 0.
            "$term" --title=yazi-picker \
                --window-width=110 --window-height=30 \
                --quit-after-last-window-closed=true \
                --abnormal-command-exit-runtime=1 \
                -e "$@"
            ;;
        wezterm)
            # --config must precede the subcommand. `start` has no title option,
            # so register a format-window-title handler as a side effect of the
            # initial_cols expression to pin the title. exit_behavior etc. are
            # overridden because a user config with Hold would block forever.
            "$term" \
                --config "initial_cols=(function() local wezterm = require('wezterm'); wezterm.on('format-window-title', function() return 'yazi-picker' end); return 110 end)()" \
                --config initial_rows=30 \
                --config 'exit_behavior="Close"' \
                --config quit_when_all_windows_are_closed=true \
                start --always-new-process -- "$@"
            ;;
        alacritty)
            # -e must be the last flag. --title also suppresses dynamic title changes.
            "$term" --title yazi-picker \
                -o window.dimensions.columns=110 \
                -o window.dimensions.lines=30 \
                -e "$@"
            ;;
    esac
}

start_dir=${1:-$HOME}
if [ ! -d "$start_dir" ]; then
    printf 'yazi-pick: no such directory: %s\n' "$start_dir" >&2
    exit 1
fi

# Single-instance lock (rapid re-triggering would make pickers and keystrokes
# fight each other).
LOCK=${TMPDIR:-/tmp}/yazi-pick.lock
if ! mkdir "$LOCK" 2>/dev/null; then
    oldpid=$(cat "$LOCK/pid" 2>/dev/null || true)
    if [ -n "$oldpid" ] && kill -0 "$oldpid" 2>/dev/null; then
        exit 0
    fi
    # A previous run crashed and left a stale lock; take it over.
fi
printf '%s' $$ >"$LOCK/pid"

chooser=$(mktemp)
trap 'rm -f "$chooser"; rm -rf "$LOCK"' EXIT

# Remember the app showing the dialog (the frontmost app) and the title of its
# focused window (the dialog itself; reactivating the app after the picker may
# hand key status to a different window, so the dialog must be re-raised).
front_pid='' front='' front_win=''
if [ -n "$HELPER" ]; then
    IFS=$'\t' read -r front_pid front front_win < <("$HELPER" frontmost 2>>"$LOG") || true
fi
if [ -z "$front_pid" ]; then
    IFS=$'\t' read -r front front_win < <(osascript -e '
        tell application "System Events"
            set p to first application process whose frontmost is true
            set wname to ""
            try
                set wname to name of value of attribute "AXFocusedWindow" of p
            end try
            return (name of p) & tab & wname
        end tell') || exit 1
fi

# Open yazi in a terminal window and wait until it closes.
run_picker "$YAZI" "$start_dir" --chooser-file "$chooser"

path=$(head -n1 "$chooser")

# Nothing selected: just give focus back to the original app.
if [ -z "$path" ]; then
    if [ -n "$HELPER" ] && [ -n "$front_pid" ]; then
        "$HELPER" activate "$front_pid" 2>>"$LOG" || true
    else
        osascript -e 'on run argv
            tell application "System Events" to set frontmost of process (item 1 of argv) to true
        end run' "$front" 2>>"$LOG" || true
    fi
    exit 0
fi

# ── Fast path: native helper ───────────────────────────────
if [ -n "$HELPER" ] && [ -n "$front_pid" ]; then
    if ! "$HELPER" push "$front_pid" "$path" "$front_win" 2>>"$LOG"; then
        printf '[%s] input failed front=%s(%s) path=%s\n' "$(date '+%F %T')" "$front" "$front_pid" "$path" >>"$LOG"
    fi
    exit 0
fi

# ── Fallback: osascript ────────────────────────────────────
# Number of the front app's windows as seen by the window server, resolved from
# the process name. Gecko-based browsers (Zen etc.) host their file dialogs as
# remote panels that never appear in ANY process's AX tree, so the difference
# between CG and AX window counts is our proof that such a dialog actually
# exists. Runs in the background while input_path restores focus; the
# AppleScript picks the result up from a file, so this costs no extra latency.
probe_cg_count() {
    osascript -l JavaScript - "$1" <<'EOJ'
ObjC.import('CoreGraphics');
function run(argv) {
    let pid;
    try {
        pid = Application('System Events').processes.byName(argv[0]).unixId();
    } catch (e) {
        return '0';
    }
    const info = ObjC.deepUnwrap(ObjC.castRefToObject($.CGWindowListCopyWindowInfo(1, 0))) || []; // kCGWindowListOptionOnScreenOnly
    return String(info.filter(w => w.kCGWindowOwnerPID === pid
        && w.kCGWindowAlpha > 0
        && w.kCGWindowBounds.Width >= 300
        && w.kCGWindowBounds.Height >= 150).length);
}
EOJ
}

cgfile=$(mktemp)
trap 'rm -f "$chooser" "$cgfile"; rm -rf "$LOCK"' EXIT
probe_cg_count "$front" >"$cgfile" 2>>"$LOG" &

# Input strategy (mirrored by the native helper):
# 1. CG window count > AX window count → an AX-invisible dialog really exists
#    (Gecko). Use blind keystroke mode (select-all then paste, so leftover text
#    in the field can never be concatenated with the path).
# 2. Otherwise open the Go-to-Folder sheet with Cmd+Shift+G and write the path
#    via AX -- but only into a *newly focused text field inside an AXSheet*.
#    Requiring the sheet ancestry makes it structurally impossible to type into
#    some other field (e.g. a browser's find bar) when no dialog is open.
# 3. If no such field shows up, press ESC to clean up and fail. We never fall
#    back to blind typing here.
input_path() {
    osascript - "$1" "$2" "$3" "$4" <<'EOS'
on run argv
    set frontApp to item 1 of argv
    set thePath to item 2 of argv
    set cgFile to item 3 of argv
    set frontWin to item 4 of argv
    set axCount to 0
    set goField to missing value
    set preField to missing value

    tell application "System Events"
        tell process frontApp
            -- Wait until the app showing the dialog is reliably frontmost again
            repeat 50 times
                set frontmost to true
                if frontmost then exit repeat
                delay 0.1
            end repeat
            if not frontmost then error frontApp & " did not come to front"
            delay 0.2
            set axCount to count of windows
        end tell
    end tell

    -- The CG-count probe was started in parallel by the caller; by now it has
    -- had the whole focus-restore phase to finish. Pick up its result.
    set cgCount to 0
    repeat 15 times
        try
            set raw to do shell script "cat " & quoted form of cgFile
            if raw is not "" then
                set cgCount to raw as integer
                exit repeat
            end if
        end try
        delay 0.1
    end repeat

    -- Blind mode only when an AX-invisible dialog (Gecko remote panel) exists
    if cgCount > axCount then
        log "AX-invisible dialog: using blind input (front=" & frontApp & ")"
        my blindInput(frontApp, thePath)
        return
    end if

    tell application "System Events"
        tell process frontApp
            -- Reactivation may have keyed the document window instead of the
            -- dialog; re-raise the window that was focused at pick start
            if frontWin is not "" then
                try
                    perform action "AXRaise" of (first window whose name is frontWin)
                    delay 0.15
                end try
            end if
            -- Save dialogs focus the filename field from the start; remember it
            -- so we can tell it apart from the Go-to-Folder sheet's field
            try
                set fe to value of attribute "AXFocusedUIElement"
                if my isTextInput(fe) then set preField to fe
            end try

            -- Open the Go-to-Folder sheet and wait for its text field to focus
            keystroke "g" using {command down, shift down}
            repeat 20 times
                try
                    set fe to value of attribute "AXFocusedUIElement"
                    if my isTextInput(fe) and my inSheet(fe) then
                        set isNew to true
                        if preField is not missing value then
                            try
                                if fe is preField then set isNew to false
                            end try
                        end if
                        if isNew then
                            set goField to fe
                            exit repeat
                        end if
                    end if
                end try
                delay 0.1
            end repeat

            if goField is missing value then
                key code 53 -- ESC: close whatever Cmd+Shift+G may have opened
            end if
        end tell
    end tell

    if goField is missing value then
        error "could not find the Go-to-Folder sheet (no dialog open, or unsupported app)"
    end if

    tell application "System Events"
        tell process frontApp
            set value of goField to thePath
            delay 0.1
            if value of goField is not thePath then error "failed to write the path into the field"
            key code 36 -- Go (leaves the file selected)

            -- Wait for the sheet to close and focus to return to the file list
            repeat 50 times
                try
                    if not my isTextInput(value of attribute "AXFocusedUIElement") then exit repeat
                on error
                    exit repeat
                end try
                delay 0.1
            end repeat
            delay 0.2
            key code 36 -- confirm "Open"
        end tell
    end tell
end run

-- Blind mode, for apps whose dialog is invisible to AX. Pastes via the
-- clipboard; select-all first, so leftover text is never concatenated.
on blindInput(frontApp, thePath)
    set savedClip to ""
    try
        set savedClip to the clipboard as text
    end try
    set the clipboard to thePath
    tell application "System Events"
        tell process frontApp
            keystroke "g" using {command down, shift down} -- Go-to-Folder overlay
            delay 0.5
            keystroke "a" using {command down}
            delay 0.1
            keystroke "v" using {command down}
            delay 0.3
            key code 36 -- Go
            delay 0.6
            key code 36 -- confirm "Open"
        end tell
    end tell
    delay 0.2
    try
        set the clipboard to savedClip
    end try
end blindInput

-- The Go-to-Folder field lives directly inside an AXSheet
-- (AXTextField <- AXSheet <- AXWindow)
on inSheet(el)
    tell application "System Events"
        set cur to el
        repeat 12 times
            try
                set cur to value of attribute "AXParent" of cur
                set r to role of cur
                if r is "AXSheet" then return true
                if r is "AXWindow" or r is "AXApplication" then return false
            on error
                return false
            end try
        end repeat
        return false
    end tell
end inSheet

on isTextInput(el)
    tell application "System Events"
        set r to role of el
        return r is "AXTextField" or r is "AXComboBox"
    end tell
end isTextInput
EOS
}

if ! input_path "$front" "$path" "$cgfile" "$front_win" 2>>"$LOG"; then
    printf '[%s] input failed front=%s path=%s cgcount=%s\n' "$(date '+%F %T')" "$front" "$path" "$(cat "$cgfile" 2>/dev/null)" >>"$LOG"
fi
